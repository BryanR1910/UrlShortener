# PostgreSQL
POSTGRES_DB=url_db
POSTGRES_USER=url_admin
POSTGRES_PASSWORD=cambia_esta_contraseña

# Spring Boot datasource (must match postgres settings above)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/url_db
SPRING_DATASOURCE_USERNAME=${POSTGRES_USER}
SPRING_DATASOURCE_PASSWORD=${POSTGRES_PASSWORD}
